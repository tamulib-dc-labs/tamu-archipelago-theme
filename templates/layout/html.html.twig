{#
/**
 * @file
 * tamu_theme override of html.html.twig.
 *
 * Adds a sticky institutional top bar above all theme regions.
 * Edit the #tamu-top-bar section below to customize branding and links.
 */
#}
{%-
  set body_classes = [
    logged_in ? 'user-logged-in',
    not root_path ? 'path-frontpage' : 'path-' ~ root_path|clean_class,
    node_type ? 'node--type-' ~ node_type|clean_class,
    db_offline ? 'db-offline',
    'archipelago-chiloe-theme',
  ]
-%}
{%- if attributes.hasClass('page-view-browse-by-facets') %}
  {% set attributes = attributes.setAttribute('data-bs-spy', 'scroll') %}
  {% set attributes = attributes.setAttribute('data-bs-target', '.list-scrollspy') %}
  {% set attributes = attributes.setAttribute(' data-bs-smooth-scroll', 'true') %}
{% endif -%}
<!DOCTYPE html>
<html{{ html_attributes }}>
  <head>
    <head-placeholder token="{{ placeholder_token|raw }}">
    <title>{{ head_title|safe_join(' | ') }}</title>
    <css-placeholder token="{{ placeholder_token|raw }}">
    <js-placeholder token="{{ placeholder_token|raw }}">
  </head>
  <body{{ attributes.addClass(body_classes) }}>
    <a href="#main-content" class="visually-hidden focusable skip-link">
      {{ 'Skip to main content'|t }}
    </a>

    {# ============================================================
       TAMU Institutional Top Bar
       Edit links, logo, and text here to match your institution.
       ============================================================ #}
